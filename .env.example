# Canonical defaults — copy to .env and override per host.
# Loaded automatically by Make via ?= fallbacks.

# === Docker image coordinates ===
# Push target is ${DOCKER_LOGIN}/${IMAGE_NAME}:${IMAGE_TAG} on Docker Hub.
DOCKER_REGISTRY=registry-1.docker.io
DOCKER_LOGIN=
# DOCKER_PWD is a secret: keep in your gitignored .env, NEVER on the
# command line (passes via stdin to `docker login --password-stdin`).
# DOCKER_PWD=
IMAGE_NAME=apacheds-ad
IMAGE_TAG=latest

# === Build output ===
JAR_PATH=target/ldap-server.jar

# === LDAP server runtime ===
LDIF_DIR=target/classes/
LDAP_PORT=10389
# Leave LDAPS_PORT empty to disable SSL; set (e.g. 10636) and provide
# a keystore via JAVA_OPTS / extra CLI args to enable.
LDAPS_PORT=
BIND_ADDRESS=0.0.0.0
