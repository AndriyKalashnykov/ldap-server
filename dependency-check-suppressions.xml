<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        Empty suppressions stub. Add entries here ONLY when:
          - The finding is a confirmed false positive, AND
          - The notes block names the re-evaluation trigger (next upstream
            version, dependency bump that drops the vulnerable transitive,
            etc.) so the suppression doesn't rot indefinitely.

        Pinning suppressions to a specific resolved version is fine; just make
        sure to delete the entry the moment the package moves past that
        version (or update the regex to cover the new vulnerable range).

        See https://jeremylong.github.io/DependencyCheck/general/suppression.html
    -->
    <suppress>
        <notes><![CDATA[
            False positive. dependency-check CPE-matches the ApacheDS packages
            (org.apache.directory.server:* — an LDAP server) to
            cpe:2.3:a:apache:apache_http_server, dragging in CVE-2010-1151, an
            Apache HTTP Server mod_auth_* race condition that does not apply to
            ApacheDS. Pinned to 2.0.0.AM27; re-evaluate (and delete or re-range)
            when bumping past AM27.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.directory\.server/.*@2\.0\.0\.AM27$</packageUrl>
        <cve>CVE-2010-1151</cve>
    </suppress>
</suppressions>
